{
    "actorSpecification": 1,
    "name": "tiktok-video-scraper-downloader",
    "title": "TikTok Video Scraper & Downloader",
    "description": "Scrapes TikTok user profiles to collect video metadata and optionally downloads MP4 files to Apify Key-Value Store.",
    "version": "1.0",
    "buildTag": "latest",
    "dockerfile": "../Dockerfile",
    "input": "../.actor/input_schema.json",
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "views": {
                "overview": {
                    "title": "Videos Overview",
                    "transformation": {
                        "fields": [
                            "id",
                            "description",
                            "createTime",
                            "author",
                            "stats",
                            "url",
                            "storageUrl"
                        ]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "id":          { "label": "Video ID",    "format": "text" },
                            "description": { "label": "Description", "format": "text" },
                            "createTime":  { "label": "Created At",  "format": "date" },
                            "url":         { "label": "TikTok URL",  "format": "link" },
                            "storageUrl":  { "label": "MP4 Download","format": "link" }
                        }
                    }
                }
            }
        }
    }
}
