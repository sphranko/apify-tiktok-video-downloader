{
    "actorSpecification": 1,
    "name": "tiktok-video-scraper-downloader",
    "title": "TikTok Video Scraper & Downloader",
    "description": "Scrapes TikTok user profiles to collect video metadata and optionally downloads MP4 files to Apify Key-Value Store.",
    "version": "1.0",
    "buildTag": "latest",
    "dockerfile": "../Dockerfile",
    "input": "../.actor/input_schema.json",
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "views": {
                "overview": {
                    "title": "Videos",
                    "transformation": {
                        "fields": [
                            "videoMeta.cover",
                            "authorMeta.name",
                            "text",
                            "createTimeISO",
                            "playCount",
                            "diggCount",
                            "commentCount",
                            "shareCount",
                            "videoMeta.duration",
                            "musicMeta.musicName",
                            "webVideoUrl",
                            "storageUrl"
                        ]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "videoMeta.cover":      { "label": "Cover",       "format": "image" },
                            "authorMeta.name":      { "label": "Author",      "format": "text" },
                            "text":                 { "label": "Description",  "format": "text" },
                            "createTimeISO":        { "label": "Published",    "format": "text" },
                            "playCount":            { "label": "Plays",        "format": "number" },
                            "diggCount":            { "label": "Likes",        "format": "number" },
                            "commentCount":         { "label": "Comments",     "format": "number" },
                            "shareCount":           { "label": "Shares",       "format": "number" },
                            "videoMeta.duration":   { "label": "Duration (s)", "format": "number" },
                            "musicMeta.musicName":  { "label": "Music",        "format": "text" },
                            "webVideoUrl":          { "label": "TikTok URL",   "format": "link" },
                            "storageUrl":           { "label": "MP4 Download", "format": "link" }
                        }
                    }
                }
            }
        }
    }
}
