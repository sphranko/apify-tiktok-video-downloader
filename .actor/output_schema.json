{
    "actorOutputSchemaVersion": 1,
    "schemaVersion": 1,
    "title": "TikTok Video record",
    "description": "Dataset record schema for a single TikTok video produced by the actor.",
    "type": "object",
    "properties": {
        "id": { "type": "string", "description": "Video ID", "template": "{{id}}" },
        "text": { "type": "string", "description": "Video caption/description", "template": "{{text}}" },
        "createTimeISO": { "type": "string", "template": "{{createTimeISO}}" },

        "author": {
            "type": "object",
            "description": "Author information",
            "template": "{{author.name}}",
            "properties": {
                "name": { "type": "string" },
                "avatar": { "type": "string" }
            }
        },

        "playCount": { "type": "integer", "template": "{{playCount}}" },
        "diggCount": { "type": "integer", "template": "{{diggCount}}" },
        "commentCount": { "type": "integer", "template": "{{commentCount}}" },
        "shareCount": { "type": "integer", "template": "{{shareCount}}" },
        "collectCount": { "type": "integer", "template": "{{collectCount}}" },

        "video": {
            "type": "object",
            "description": "Video metadata",
            "template": "{{video.cover}}",
            "properties": {
                "duration": { "type": "number" },
                "cover": { "type": "string" },
                "width": { "type": "integer" },
                "height": { "type": "integer" }
            }
        },

        "music": {
            "type": "object",
            "description": "Music / sound metadata",
            "template": "{{music.name}}",
            "properties": {
                "name": { "type": "string" },
                "author": { "type": "string" },
                "original": { "type": "boolean" }
            }
        },

        "webVideoUrl": { "type": "string", "template": "{{webVideoUrl}}" },

        "storageKey": { "type": "string", "template": "{{storageKey}}" },
        "storageUrl": { "type": "string", "template": "{{storageUrl}}" }
    },
    "required": ["id", "webVideoUrl"]
}

